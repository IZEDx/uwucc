{
	"$schema": "https://raw.githubusercontent.com/MCJack123/TypeScriptToLua/master/tsconfig-schema.json",
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext"],
		"moduleResolution": "node",
		"strict": true,
		"types": [
			"./types",
			"@jackmacwindows/lua-types/cc-5.2",
			"@jackmacwindows/craftos-types",
			"@jackmacwindows/cc-types"
		],
		"outDir": "dist",
		"rootDir": "src",
		"jsx": "react",
		"jsxFactory": "UwUi.node"
	},
	"tstl": {
		"luaTarget": "CC-5.2",
		"noImplicitSelf": true,
		"luaLibImport": "require",
		"noImplicitGlobalVariables": true,
		"sourceMapTraceback": true,
		"luaPlugins": [{ "name": "./tstl-plugin.ts" }]
		//"luaBundle": "startup.lua",
		//"luaBundleEntry": "src/startup.ts"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
